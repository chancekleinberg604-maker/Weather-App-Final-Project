<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane prefHeight="550.0" prefWidth="650.0"
            style="-fx-background-color: linear-gradient(to bottom, #89CFF0, #1E90FF);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="FinalProject.WeatherViewController">
    <children>

        <ImageView fx:id="imgBackground" fitHeight="550.0" fitWidth="650.0"
                   opacity="0.25" preserveRatio="true" />

        <Label fx:id="locationLabel"
               layoutX="40" layoutY="100"
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"
               text="City, State" />

        <Rectangle arcHeight="30.0" arcWidth="30.0"
                   fill="#f9fbff"
                   height="420.0" width="380.0"
                   layoutX="20.0" layoutY="140.0"
                   opacity="0.95"
                   stroke="#d9e4f1" strokeWidth="1.5"
                   style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 15, 0.5, 0, 4);" />

        <Label text="Temperature:" layoutX="40" layoutY="180"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        <Label fx:id="tempLabel" layoutX="200" layoutY="180"
               style="-fx-font-size: 18px; -fx-text-fill: #34495e;" />

        <Label text="Wind Speed:" layoutX="40" layoutY="230"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        <Label fx:id="windLabel" layoutX="200" layoutY="230"
               style="-fx-font-size: 18px; -fx-text-fill: #34495e;" />

        <Label text="Wind Direction:" layoutX="40" layoutY="280"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        <Label fx:id="windDirLabel" layoutX="200" layoutY="280"
               style="-fx-font-size: 18px; -fx-text-fill: #34495e;" />

        <Label text="Humidity:" layoutX="40" layoutY="330"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        <Label fx:id="humidityLabel" layoutX="200" layoutY="330"
               style="-fx-font-size: 18px; -fx-text-fill: #34495e;" />

        <Label text="Pressure:" layoutX="40" layoutY="380"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        <Label fx:id="pressureLabel" layoutX="200" layoutY="380"
               style="-fx-font-size: 18px; -fx-text-fill: #34495e;" />

        <Label text="Condition:" layoutX="40" layoutY="430"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #34495e;" />
        <Label fx:id="conditionLabel" layoutX="200" layoutY="430"
               style="-fx-font-size: 18px; -fx-text-fill: #34495e;" />

        <TextField fx:id="zipField" layoutX="120" layoutY="40"
                   promptText="Enter ZIP Code"
                   onAction="#onFetchWeather"
                   style="-fx-background-radius: 12; -fx-border-radius: 12;
                          -fx-border-color: #d1d8e0; -fx-border-width: 1;
                          -fx-padding: 8; -fx-font-size: 16px;" />

        <Button text="Submit" fx:id="btnSubmit"
                layoutX="330" layoutY="40"
                onAction="#onFetchWeather"
                prefHeight="40" prefWidth="110"
                style="-fx-background-color: linear-gradient(to right, #3a7bd5, #00d2ff);
                       -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-background-radius: 20;
                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 8, 0.4, 0, 2);" />

        <Label fx:id="errorLabel" layoutX="150" layoutY="5"
               style="-fx-text-fill: white; -fx-background-color: red;
                      -fx-background-radius: 20; -fx-font-size: 16px;
                      -fx-font-weight: bold; -fx-padding: 5;"
               opacity="0.0" />

        <ImageView fx:id="imgDayOrNight" fitHeight="300" fitWidth="260"
                   layoutX="420" layoutY="180"
                   preserveRatio="true"
                   style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0.4, 0, 2);" />
    </children>
</AnchorPane>
